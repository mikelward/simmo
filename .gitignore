# Ignore all dotfiles and dot-directories by default; allowlist below.
.*
!/.github
!/.github/**
!/.gitignore
!.gitkeep
# Claude Code shared config (SessionStart hook + settings) must be tracked so
# remote web sessions pick it up; keep machine-local overrides ignored.
!/.claude
!/.claude/**
/.claude/settings.local.json
# Transient agent worktrees created by the Claude Code harness; never committed.
/.claude/worktrees/
# Transient scheduler lock/state from the Claude Code harness; session-local only.
/.claude/scheduled_tasks.lock
/.claude/scheduled_tasks.json

*.iml
/local.properties
/build
/captures
local.properties
app/build
*.keystore
*.jks

# JVM fatal-error / replay crash dumps from forked test workers
hs_err_pid*.log
replay_pid*.log
