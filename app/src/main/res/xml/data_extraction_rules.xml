<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+. Same policy as backup_rules.xml: cloud backups and
     device-to-device transfers carry only Simmo's own state files. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
