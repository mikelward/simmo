<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Enumerate subscriptions and phone accounts for the snapshot. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Show each SIM's own number on the SIMs screen, and read other apps'
         calling-account labels ("SIP – work" — TelecomManager.getPhoneAccount
         needs it on Android 12+). Same Phone permission group as
         READ_PHONE_STATE, so it's requested with it in one dialog; if denied,
         account labels degrade to the providing app's name. -->
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />

    <!-- Simmo shows no ads: strip the advertising-ID and ad-attribution
         permissions the Firebase Analytics dependency would otherwise merge in. -->
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.ACCESS_ADSERVICES_AD_ID"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION"
        tools:node="remove" />

    <!-- Re-place calls from the chooser (TelecomManager.placeCall); requested
         at runtime on first use. -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- The SIM-assist nudges: "your SIM is now active, place the call?" and
         "new SIM seen". Optional; everything degrades to the in-app surfaces. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- The roaming watch's connectivity layer (SPEC "Data-roaming
         visibility"): register the cellular network callback and read its
         roaming capability. Normal install-time permission — auto-granted,
         no dialog. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Wake after reboot to re-register that callback (registrations don't
         survive one). Normal install-time permission — auto-granted, no
         dialog. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Resolve a dialed number to a contact for app-to-app hand-off (e.g.
         WhatsApp); optional, requested at runtime when such a rule is created. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Simmo routes carrier calls, but must still install on devices without a
         radio so rules can be reviewed there. -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- Android 11+ package visibility: see whether app-to-app hand-off targets
         are installed (to offer them in the editor) and launch their call. -->
    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.google.android.apps.googlevoice" />
        <package android:name="com.microsoft.teams" />
        <package android:name="com.viber.voip" />
        <package android:name="com.yollacalls" />
        <package android:name="com.roamless.roamless" />
        <!-- See the apps behind non-SIM calling accounts (SIP providers, VoIP
             apps) — anyone with a ConnectionService — to label their accounts
             by app name when the account's own label isn't readable. -->
        <intent>
            <action android:name="android.telecom.ConnectionService" />
        </intent>
    </queries>

    <application
        android:name=".SimmoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Simmo">

        <!-- Telemetry never starts on its own: collection stays off until
             SimmoApp applies the persisted "Make Simmo better" choice, and
             both SDKs then remember the applied value across process starts.
             Inert in builds without a Firebase config (see SETUP.md). -->
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="false" />
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="false" />
        <meta-data
            android:name="google_analytics_default_allow_ad_personalization_signals"
            android:value="false" />
        <!-- The personalization flag above only marks events non-personalized;
             this one stops Analytics reading the advertising ID at all, backing
             the stripped AD_ID permissions on OS versions where the ID is
             readable without them. -->
        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The Ask chooser, launched by the redirection service mid-call-
             attempt; not part of recents or the launcher. -->
        <activity
            android:name=".ui.ChooserActivity"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- The delay-before-calling countdown, likewise launched by the
             redirection service mid-call-attempt. -->
        <activity
            android:name=".ui.DelayedCallActivity"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- The Quick Settings tile: a shortcut into the SIMs screen (apps
             cannot toggle SIMs themselves, so a fast path to the management
             screens is the whole job). -->
        <service
            android:name=".tile.ManageSimsTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_sim"
            android:label="@string/sim_registry_title"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Roaming-watch wake-ups (SPEC "Data-roaming visibility"): all
             three actions are exempt from the implicit-broadcast
             restrictions, so they start a dead process at the moments that
             matter — a timezone change after landing, a SIM load, and boot
             (which re-registers the connectivity callback by starting the
             process). The connectivity callback's own fires arrive as an
             explicit PendingIntent broadcast, which needs no filter entry.
             Not exported: the system reaches a private receiver for its own
             broadcasts, and exporting would let any app force
             telephony/DataStore work at will. -->
        <receiver
            android:name=".telecom.DataWatchReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.telephony.action.CARRIER_CONFIG_CHANGED" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- The interception hook: the platform binds here for every outgoing
             carrier call while Simmo holds ROLE_CALL_REDIRECTION. -->
        <service
            android:name=".telecom.SimmoCallRedirectionService"
            android:exported="true"
            android:permission="android.permission.BIND_CALL_REDIRECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallRedirectionService" />
            </intent-filter>
        </service>
    </application>

</manifest>
