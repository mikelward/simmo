<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Enumerate subscriptions and phone accounts for the snapshot. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Re-place calls from the chooser (TelecomManager.placeCall); requested
         at runtime on first use. -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- Simmo routes carrier calls, but must still install on devices without a
         radio so rules can be reviewed there. -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:name=".SimmoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Simmo">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The Ask chooser, launched by the redirection service mid-call-
             attempt; not part of recents or the launcher. -->
        <activity
            android:name=".ui.ChooserActivity"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- The interception hook: the platform binds here for every outgoing
             carrier call while Simmo holds ROLE_CALL_REDIRECTION. -->
        <service
            android:name=".telecom.SimmoCallRedirectionService"
            android:exported="true"
            android:permission="android.permission.BIND_CALL_REDIRECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallRedirectionService" />
            </intent-filter>
        </service>
    </application>

</manifest>
